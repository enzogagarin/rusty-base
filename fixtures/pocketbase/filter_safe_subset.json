{
  "name": "PocketBase safe filter subset",
  "context": "none",
  "schema": [
    { "name": "id", "kind": "text" },
    { "name": "name", "kind": "text" },
    { "name": "owner", "kind": "text" },
    { "name": "status", "kind": "bool" },
    { "name": "score", "kind": "number" },
    { "name": "created", "kind": "datetime" },
    { "name": "tags", "kind": "array" },
    { "name": "profile", "kind": "json" }
  ],
  "cases": [
    {
      "name": "text equality",
      "filter": "name = 'Burak'",
      "expectedSql": "\"name\" = ?",
      "expectedParams": [{ "type": "string", "value": "Burak" }],
      "expectedBehavior": "allowed",
      "pocketBaseNote": "PocketBase accepts single-quoted string equality in collection filters and rules."
    },
    {
      "name": "boolean and numeric grouping",
      "filter": "status = true && score >= 10",
      "expectedSql": "\"status\" = TRUE AND \"score\" >= ?",
      "expectedParams": [{ "type": "number", "value": "10" }],
      "expectedBehavior": "allowed",
      "pocketBaseNote": "PocketBase filters combine boolean values and numeric comparisons with &&."
    },
    {
      "name": "array any-match",
      "filter": "tags ?= 'rust'",
      "expectedSql": "EXISTS (SELECT 1 FROM json_each(\"tags\") WHERE json_each.value = ?)",
      "expectedParams": [{ "type": "string", "value": "rust" }],
      "expectedBehavior": "allowed",
      "pocketBaseNote": "PocketBase uses ?= for any-match checks against multi-value fields."
    },
    {
      "name": "json path equality",
      "filter": "profile.name = 'Ada'",
      "expectedSql": "json_extract(\"profile\", '$.name') = ?",
      "expectedParams": [{ "type": "string", "value": "Ada" }],
      "expectedBehavior": "allowed",
      "pocketBaseNote": "PocketBase supports dotted JSON path access in filter expressions."
    },
    {
      "name": "datetime macro",
      "filter": "created <= @now",
      "expectedSql": "\"created\" <= ?",
      "expectedParams": [{ "type": "string", "value": "2026-05-12 16:30:45.123Z" }],
      "expectedBehavior": "allowed",
      "pocketBaseNote": "PocketBase date macros are resolved before SQL execution; this fixture pins the clock."
    }
  ]
}
